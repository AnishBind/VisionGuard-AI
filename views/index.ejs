                <div class="footerlinklists">
                    <h3>FOLLOW</h3>
                    <br>
                    <ul>
                        <li>Ramnarain Ruia Autonomus collge on LN road near Matunga railway station</li>
                        <li><p>+91-9387538446</p></li>
                        <li><p>HealthConnect@gmail.com</p></li>
                        <li><div class="socialmedia">
                            <img src="https://vsmthane.org/wp-content/plugins/ultimate-social-media-icons/images/icons_theme/default/default_facebook.png" alt="">
                            <img src="https://vsmthane.org/wp-content/plugins/ultimate-social-media-icons/images/icons_theme/default/default_twitter.png" alt="">
                            <img src="https://vsmthane.org/wp-content/plugins/ultimate-social-media-icons/images/icons_theme/default/default_youtube.png" alt="">
                            <img src="https://vsmthane.org/wp-content/plugins/ultimate-social-media-icons/images/icons_theme/default/default_linkedin.png" alt="">
                            <img src="https://vsmthane.org/wp-content/plugins/ultimate-social-media-icons/images/icons_theme/default/default_instagram.png" alt="">
                        </div></li>
                    </ul>
                </div>
            </div>
            <p>Copyright &copy; 2024 by @HealthConnect | All Rights Reserved.</p>
        </div>

    </footer>


    <script>
        function slideshow(){    
            document.getElementById("slideshowImages").src = arr[i];
            i = i + 1;
            if (i===4){
                i=0;
            }
        }

        let i = 0
        const arr = [
                    "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQ3nI_IzMZq_xlIE_a6wrgFbWYjhWiIzEtROw&s",
                    "https://static.toiimg.com/thumb/msid-90530148,width-1280,height-720,resizemode-72/90530148.jpg",
                    "https://wallpapers.com/images/hd/doctor-and-patient-consultation-xzr1nkob3w9mlgzc.jpg",
