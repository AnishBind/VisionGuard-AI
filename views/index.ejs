                </div>
            </a>

            <a class="option" href="/login">
                <div class="option_div">
                    <img style="width: 90%;" src="https://img.freepik.com/premium-vector/appointment-booking-smartphone-concept_23-2148559939.jpg" alt="Ambukance Image">
                    <div>Book Appointments</div>
                </div>
            </a>
        </div>
    </section>

    <footer class="footer">
        <div class="footer_text">
            <div class="footerlinks">

                <div class="footerlinklists">
                    <h3>SPECIALITY</h3>
                    <br>
                    <ul>
