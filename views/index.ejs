<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Health Connect</title>

<style>
    *{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Nunito, sans-serif;
    scroll-behavior: smooth;
}

:root{
    --bg-color: #ffffff;
    --main-color: #2393d2;
    --text-color: #000000;
    --secondary-color: #f4821f;
}


nav{
    width: 100vw;
    height: 3.5rem;
    background-color: #231F20;
    padding: 0 5%;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

nav h1{
    color: var(--bg-color);
}

nav a{
    height: 2rem;
    padding: 0px 1.4rem;
    background-color: var(--main-color);
    color: #ffffff;
    border-radius: 1.5rem;
    transition: 0.3s;
    align-content: center;
    text-decoration: none;
    font-weight: 700;
}

nav a:hover{
    color: var(--text-color);
}


.herosection img{
    height: 70vh;
    width: 100%;    
}

.options{
    width: 100vw;
    padding: 2.5rem 5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.option{
    width: 100%;
    margin: 0 5%;
    height: 15rem;
    text-decoration: none;
    border: 0.5px solid black;
    border-radius: 5px;
}

.option:hover{
    opacity: 0.9;
    background-color: rgb(255, 252, 252);
    background-blend-mode:multiply;
    color: rgb(240, 79, 133);
}

.option_div{
    width: 100%;
    height: 100%;
    padding: 1rem 0;
    font-size: 1.2rem;
    font-weight: 700;
    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
}

.option_div img{
    width: 100%;
}

.option_div div{
    text-align: center;
}

.footer{
    width: 100vw;
    padding: 2rem 9%;
    background-color: black;
    color: white;
}

.footer h3{
    color: var(--main-color);
}

.footerlinks{
    display: flex;
    padding: 3% 10%;
    background-color: black;
    transition: 1s;
}

.footerlinklists{
    width: 100%;
    color: #ffffff;
    padding-right: 5%;
    transition: 1s;
    font-size: .9rem;
}

.footerlinklists li{
    list-style-type: none;
    padding-bottom: 2%;
}

.footerlinklists a{
    text-decoration: none;
    color: #ffffff;
}

.socialmedia{
    display: flex;
}

.socialmedia img{
    width: 2rem;
    height: 2rem;
    padding: .2rem .2rem;
    cursor: pointer;
}

</style>

</head>
<body>
    
    <header>
        <nav>
            <h1>HealthConnect</h1>
            <a href="/login">Login</a>
        </nav>
    </header>

    <section>
        <div class="herosection">
            <img id="slideshowImages" src="https://i.pinimg.com/564x/c5/81/a6/c581a618883e2ab8ceef553b5fdcc582.jpg" alt="">
        </div>
    </section>

    <section>
        <div class="options">
            <a class="option" href="/login">
                <div class="option_div">
                    <img src="https://www.successmantra.in/assets/assestsnew/images/login-registration.png" alt="Ambukance Image">
                    <div>Register Now</div>
                </div>
            </a>

            <a class="option" href="/login">
                <div class="option_div">
                    <img src="https://static.vecteezy.com/system/resources/thumbnails/029/338/731/small_2x/ambulance-car-illustration-emergency-medical-service-vehicle-isolated-on-white-background-vector.jpg" alt="Ambukance Image">
                    <div>Call An Ambulance</div>
                </div>
            </a>

            <a class="option" href="/login">
                <div class="option_div">
